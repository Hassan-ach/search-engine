# Boogle - Environment Configuration Example
# Copy this file to .env and customize as needed

# ============================================
# PostgreSQL (all services)
# ============================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=password
PG_DBNAME=boogle

# Connection pooling
PG_MAX_OPEN_CONNS=20
PG_MAX_IDLE_CONNS=20
PG_MAX_CONN_LIFETIME=0
PG_BATCH_SIZE=30

# ============================================
# Redis (Spider)
# ============================================
REDIS_ADDR=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_DELAY=5
REDIS_MAX_RETRY=10

# ============================================
# Spider Configuration
# ============================================
MAX_CRAWLERS=20
HTTP_TIMEOUT=60
CRAWLER_TIMEOUT=60
MAX_CONCURRENT_FETCH=200
CRAWLER_DELAY=200
LOGS_PATH=./logs/spider.log

# ============================================
# Indexer Configuration
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/boogle
PG_MAX_CONNECTIONS=10
PG_MIN_CONNECTIONS=2
ACQUIRE_TIMEOUT_SECONDS=5
WORD_BATCH_SIZE=1000
PAGE_WORD_BATCH_SIZE=500
LOOP_DELAY_MS=100
INDEXER_COUNT=4
LOG_PATH=./logs/indexer.log

# ============================================
# Engine Configuration
# ============================================
PAGE_SIZE=20
RANKER_MAX_RESULTS=100
RANKER_WEIGHT_TF=0.5

# ============================================
# Ranking Configuration
# ============================================
PR_SCHEDULE=0 0 * * *
IDF_SCHEDULE=0 1 * * *
BACK_LINKS_RUN_ON_STARTUP=true
