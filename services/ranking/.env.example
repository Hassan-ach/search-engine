# Ranking Service - Environment Configuration
# (from services/ranking/src/main.py and src/psql.py)

# ===== Database Configuration - REQUIRED =====
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=boogle
PG_USER=postgres
PG_PASSWORD=password

# ===== Ranking Job Scheduling =====
# Cron format: minute hour day month weekday
# 0 0 * * * = every midnight (00:00)
# 0 1 * * * = every 01:00 AM
PR_SCHEDULE=0 0 * * *          # PageRank schedule (default: midnight)
IDF_SCHEDULE=0 1 * * *         # IDF calculation schedule (default: 1 AM)

# ===== Startup Configuration =====
BACK_LINKS_RUN_ON_STARTUP=true  # Run ranking jobs on startup (true/false)
