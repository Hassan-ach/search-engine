# Indexer Service - Environment Configuration
# (from services/indexer/src/core/config.rs)

# ===== Database - REQUIRED =====
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://admin:1234@psql:5432/se

# Database Connection Pooling
PG_MAX_CONNECTIONS=10          # Max pool connections
PG_MIN_CONNECTIONS=2           # Min pool connections
ACQUIRE_TIMEOUT_SECONDS=5      # Connection acquire timeout

# Database Batch Sizes
WORD_BATCH_SIZE=1000           # Words insert batch size
PAGE_WORD_BATCH_SIZE=500       # Page-word insert batch size

# ===== Indexer Configuration =====
INDEXER_COUNT=4                # Number of concurrent workers
LOOP_DELAY_MS=100              # Delay between fetch cycles (ms)
LOG_PATH=./logs/indexer.log    # Log file location
