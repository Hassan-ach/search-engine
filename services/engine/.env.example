# Engine Service - Environment Configuration
# Database Connection (from store.config.go)
PG_HOST=psql
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=1234
PG_DBNAME=se

# Database Connection Pooling
PG_MAX_OPEN_CONNS=20
PG_MAX_IDLE_CONNS=20

# Engine Configuration (from ranker.config.go and store.config.go)
PAGE_SIZE=20                      # Results per page
RANKER_MAX_RESULTS=100            # Maximum results for ranking
RANKER_WEIGHT_TF=0.5              # TF weight in ranking formula
